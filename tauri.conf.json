{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Live Interpreter",
  "version": "0.1.0",
  "identifier": "app.live-interpreter.desktop",
  "build": {
    "frontendDist": "desktop"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Live Interpreter",
        "width": 1120,
        "height": 760,
        "minWidth": 900,
        "minHeight": 620,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
